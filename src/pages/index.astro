---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import PowerCalculator from '../components/PowerCalculator.astro';
import LithiumComparison from '../components/LithiumComparison.astro';

// Icons using Heroicons SVG strings
const icons = {
  battery: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5h6.75V15H4.5v-4.5zM3 7.5h15c.828 0 1.5.672 1.5 1.5v6c0 .828-.672 1.5-1.5 1.5H3c-.828 0-1.5-.672-1.5-1.5v-6C1.5 8.172 2.172 7.5 3 7.5z" /></svg>`,
  inverter: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  inverterBattery: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
  coolant: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
  oil: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
  solar: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`
};

const products = [
  {
    title: 'Automotive Batteries',
    description: 'High-performance, maintenance-free batteries designed to deliver reliable starting power in extreme conditions.',
    icon: icons.battery,
    colorClass: 'text-yellow-500',
    guide: 'Always ensure battery terminals are clean and securely tightened. Check the indicator eye periodically; a green color usually indicates a healthy charge. For maximum lifespan, avoid completely discharging the battery and have the charging system checked if the vehicle hesitates to start.'
  },
  {
    title: 'Inverters',
    description: 'Pure sine wave inverters that ensure seamless power backup and protection for your sensitive electronics.',
    icon: icons.inverter,
    colorClass: 'text-blue-500',
    guide: 'Keep the inverter in a well-ventilated, dry area away from direct sunlight. Regularly dust the vents to prevent overheating. Ensure the load connected does not exceed the inverter\'s rated capacity to avoid tripping or internal damage.'
  },
  {
    title: 'Inverter Batteries',
    description: 'Deep cycle tubular batteries built for long-lasting performance and consistent power delivery during outages.',
    icon: icons.inverterBattery,
    colorClass: 'text-yellow-500',
    guide: 'For tubular and lead-acid batteries, check the water levels every 2-3 months and top up only with distilled water to the specified mark. Keep the battery surface clean and apply petroleum jelly on the terminals to prevent corrosion.'
  },
  {
    title: 'Coolant',
    description: 'Premium anti-freeze coolant formulated to protect your engine against overheating and corrosion.',
    icon: icons.coolant,
    colorClass: 'text-blue-500',
    guide: 'Check coolant levels when the engine is completely cold. Maintain the level between the MIN and MAX marks on the reservoir. Never open the radiator cap when the engine is hot. Flush and replace the coolant according to your vehicle manufacturer\'s recommended intervals.'
  },
  {
    title: 'Engine Oil',
    description: 'Advanced synthetic oils that reduce wear, improve fuel economy, and extend engine life.',
    icon: icons.oil,
    colorClass: 'text-yellow-500',
    guide: 'Regularly check the oil level using the dipstick when the engine is warm but turned off for a few minutes. Change the engine oil and filter at the recommended mileage or time intervals to ensure optimal engine lubrication and performance.'
  },
  {
    title: 'Solar Solutions',
    description: 'High-efficiency solar panels and complete solar power systems for sustainable and cost-effective energy.',
    icon: icons.solar,
    colorClass: 'text-blue-500',
    guide: 'Keep solar panels clean and free from dust, leaves, or bird droppings by gently washing them with water and a soft sponge. Have a professional inspect the wiring, inverter connections, and panel mounts annually to ensure optimal energy generation.'
  }
];

const brands = [
  { name: 'Amaron', image: '${base}/images/brands/amaron.jpg' },
  { name: 'SF Batteries', image: '${base}/images/brands/sf_battery.png' },
  { name: 'Okaya', image: '${base}/images/brands/okaya.jpg' },
  { name: 'Luminous', image: '${base}/images/brands/luminous.png' },
  { name: 'Microtek', image: '${base}/images/brands/microtek.png' }
];
---

<Layout title="Home">
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="relative pt-24 pb-32 lg:pt-36 lg:pb-40 overflow-hidden">
      <!-- Background Elements -->
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-slate-900 opacity-90"></div>
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blue-500/20 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 rounded-full bg-yellow-500/10 blur-3xl"></div>
        <!-- Grid pattern overlay -->
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-20"></div>
      </div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-800/80 border border-slate-700 backdrop-blur-sm mb-6 text-sm font-medium text-blue-400">
            <span class="flex w-2 h-2 rounded-full bg-blue-500 mr-2 animate-pulse"></span>
            Powering Your Journey
          </div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-extrabold text-white tracking-tight mb-8 leading-tight">
            Reliable Energy <br class="hidden sm:block" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-yellow-600">Whenever You Need It</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
            Dave Enterprises is a premier retailer of top-brand automotive batteries, inverters, and premium engine fluids, featuring trusted names like Amaron, SF Batteries, Okaya, Luminous, and Microtek. Keep moving forward with power you can trust.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="#products" class="w-full sm:w-auto px-8 py-4 bg-yellow-500 hover:bg-yellow-400 text-slate-900 font-bold rounded-lg transition-all duration-300 shadow-lg shadow-yellow-500/25 hover:shadow-yellow-500/40 hover:-translate-y-0.5">
              Explore Products
            </a>
            <a href="#contact" class="w-full sm:w-auto px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg border border-slate-700 transition-all duration-300">
              Contact Sales
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trusted Brands Section -->
    <section class="py-16 bg-slate-900 border-y border-slate-800 relative z-10 shadow-2xl">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-semibold text-slate-400 uppercase tracking-wider mb-10">Authorized Dealer for Industry-Leading Brands</p>
        <div class="flex flex-wrap justify-center items-center gap-6 sm:gap-10 md:gap-16">
          {brands.map((brand) => (
            <div class="flex flex-col items-center group cursor-pointer">
              <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full bg-white border-2 border-slate-700 p-3 overflow-hidden shadow-xl transition-all duration-300 group-hover:scale-110 group-hover:border-blue-500 group-hover:shadow-blue-500/40 flex items-center justify-center relative">
                <div class="absolute inset-0 bg-gradient-to-br from-white to-slate-100 z-0"></div>
                <img src={brand.image} alt={brand.name} class="w-full h-full object-contain z-10 transition-transform duration-500 group-hover:scale-105" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Products Section -->
    <section id="products" class="py-24 bg-slate-950 relative">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Our Products</h2>
          <div class="w-20 h-1 bg-blue-500 mx-auto rounded-full mb-6"></div>
          <p class="text-slate-400 text-lg">Engineered for durability and performance. Discover our comprehensive range of power solutions.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-center">
          {products.map((product) => (
            <ProductCard {...product} />
          ))}
        </div>
      </div>
    </section>

    <PowerCalculator />
    <LithiumComparison />

    <!-- About Section -->
    <section id="about" class="py-24 bg-slate-900 relative overflow-hidden">
      <!-- Decorative background -->
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1/3 h-full bg-gradient-to-l from-slate-800/50 to-transparent pointer-events-none"></div>
      
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="relative">
              <div class="aspect-[4/3] rounded-2xl bg-slate-800 border border-slate-700 overflow-hidden shadow-2xl relative group">
                <img src="${base}/images/about_amaron.jpg" alt="Dave Enterprises Amaron Showroom" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent pointer-events-none"></div>
              </div>
            </div>
          </div>
          
          <div>
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-6">About Dave Enterprises</h2>
            <p class="text-slate-300 text-lg leading-relaxed mb-6">
              Founded on the principles of reliability and innovation, Dave Enterprises has grown to become a leading retailer of premium automotive power solutions from top brands like Amaron, SF Batteries, Okaya, Luminous, and Microtek. We understand that your vehicle and equipment demand uncompromising performance.
            </p>
            <p class="text-slate-400 leading-relaxed mb-8">
              Whether you need industrial-grade inverters for seamless backup power or advanced synthetic engine oils for peak vehicle performance, our curated selection of products ensures that you are always ready for the road ahead. Our team of experts is dedicated to providing tailored solutions and exceptional customer service.
            </p>
            
            <ul class="space-y-4 mb-8">
              {[
                'Premium Quality Assurance',
                'Expert Technical Support'
              ].map(item => (
                <li class="flex items-center text-slate-300">
                  <svg class="w-5 h-5 text-yellow-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-24 bg-slate-950">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">Contact Us</h2>
          <div class="w-20 h-1 bg-yellow-500 mx-auto rounded-full mb-6"></div>
          <p class="text-slate-400 text-lg">Ready to upgrade your power solutions? Reach out to us today for a quote or consultation.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl">
          <!-- Contact Info -->
          <div class="lg:col-span-2 bg-gradient-to-br from-slate-800 to-slate-900 p-10">
            <h3 class="text-2xl font-bold text-white font-heading mb-8">Contact Information</h3>
            
            <div class="space-y-8">
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 shrink-0 mr-4">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-lg font-medium text-white mb-1">Our Location</h4>
                  <p class="text-slate-400 leading-relaxed">10, Malu Sunder Market,<br />Dabok, Udaipur,<br />Rajasthan 313022</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-lg bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-500 shrink-0 mr-4">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.09-7.074-7.07l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-lg font-medium text-white mb-1">Phone Number</h4>
                  <p class="text-slate-400">+91-9636185543</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 shrink-0 mr-4">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-lg font-medium text-white mb-1">Email Address</h4>
                  <p class="text-slate-400">dave.enterprises0723@gmail.com</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Direct Connect Options -->
          <div class="lg:col-span-3 p-10 bg-slate-800/30 flex flex-col justify-center">
            <h3 class="text-2xl font-bold text-white font-heading mb-8 text-center lg:text-left">Connect With Us Directly</h3>
            
            <div class="space-y-6">
              <a href="https://wa.me/919636185543" target="_blank" rel="noopener noreferrer" class="flex items-center p-6 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl transition-all duration-300 group shadow-lg shadow-green-500/5 hover:shadow-green-500/20 hover:-translate-y-1">
                <div class="w-14 h-14 rounded-full bg-[#25D366]/10 flex items-center justify-center mr-6 shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-8 h-8 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                </div>
                <div>
                  <h4 class="text-xl font-bold text-white mb-1">WhatsApp Us</h4>
                  <p class="text-slate-400">Get instant replies to your queries</p>
                </div>
                <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="w-6 h-6 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </div>
              </a>
              
