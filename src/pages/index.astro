    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('guide-modal');
        const backdrop = document.getElementById('guide-modal-backdrop');
        const panel = document.getElementById('guide-modal-panel');
        const titleEl = document.getElementById('modal-title');
        const contentEl = document.getElementById('modal-guide-content');
        const closeBtn = document.getElementById('close-modal-btn');
        const guideButtons = document.querySelectorAll('.read-guide-btn');

        function openModal(title, guide) {
          if (!modal) return;
          titleEl.textContent = title + ' Guide';
          contentEl.textContent = guide;
          
          modal.classList.remove('hidden');
          // trigger reflow
          void modal.offsetWidth;
          
          backdrop.classList.remove('opacity-0');
          backdrop.classList.add('opacity-100');
          
          panel.classList.remove('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
          panel.classList.add('opacity-100', 'translate-y-0', 'sm:scale-100');
        }

        function closeModal() {
          if (!modal) return;
          backdrop.classList.remove('opacity-100');
          backdrop.classList.add('opacity-0');
          
          panel.classList.remove('opacity-100', 'translate-y-0', 'sm:scale-100');
          panel.classList.add('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
          
          setTimeout(() => {
            modal.classList.add('hidden');
          }, 300);
        }

        guideButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            const title = btn.getAttribute('data-title');
            const guide = btn.getAttribute('data-guide');
            openModal(title, guide);
          });
        });

        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (backdrop) backdrop.addEventListener('click', closeModal);
      });
    </script>
</Layout>
