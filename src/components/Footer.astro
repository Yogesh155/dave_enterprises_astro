---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-slate-800 pt-16 pb-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        <a href="#" class="flex items-center gap-3 mb-6">
          <img src="/images/logo.png" alt="Dave Enterprises Logo" class="h-10 w-auto object-contain bg-white rounded-md p-1" />
          <span class="font-heading font-bold text-xl tracking-tight text-white">
            Dave <span class="text-blue-500">Enterprises</span>
          </span>
        </a>
        <p class="text-slate-400 max-w-sm leading-relaxed">
          Your trusted partner in professional automotive power solutions. We provide high-quality batteries, inverters, and essential automotive fluids to keep your engines running strong.
        </p>
      </div>
      
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Home</a></li>
          <li><a href="#about" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">About Us</a></li>
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Products</a></li>
          <li><a href="#contact" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Products</h3>
        <ul class="space-y-3">
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Automotive Batteries</a></li>
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Inverters</a></li>
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Inverter Batteries</a></li>
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Coolant & Engine Oil</a></li>
          <li><a href="#products" class="text-slate-400 hover:text-yellow-400 transition-colors text-sm">Solar Solutions</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Our Location</h3>
        <div class="bg-white p-2 rounded-lg inline-block shadow-lg">
          <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://maps.app.goo.gl/BD4QhduWd3yq19Cb8" alt="Location QR Code" class="w-24 h-24" />
        </div>
        <p class="text-slate-400 text-xs mt-3 max-w-[150px]">Scan for directions to our store in Dabok</p>
      </div>
    </div>
    
    <div class="border-t border-slate-800 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-slate-500 text-sm mb-4 md:mb-0">
        &copy; {currentYear} Dave Enterprises. All rights reserved.
      </p>
      <div class="flex space-x-6 text-sm text-slate-500">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
